# =============================================================================
# JobPilot environment configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# ---- Gemini API key (required) ----
# Free tier: 15 RPM, 1M tokens/day — plenty for ~50 applications/day.
# Get one at: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ---- Gemini model ----
# Options:
#   gemini-2.0-flash  (default — fastest, free tier)
#   gemini-2.5-flash  (slightly better quality)
#   gemini-2.5-pro    (best quality, paid tier)
LLM_MODEL=gemini-2.0-flash

# ---- Browser behavior ----
HEADLESS=true
AUTO_SUBMIT=true
SCREENSHOT_ON_FAILURE=true
LOG_LEVEL=info

# ---- Stealth profile ----
# Options: patchright | playwright_stealth
STEALTH_PROFILE=patchright

# ---- Optional residential proxy (HTTP/HTTPS) ----
# PROXY_URL=http://user:pass@proxy.example.com:8000

# ---- Email (stubbed in v1) ----
# When EMAIL_ENABLED=false (default), tracker emails are written to logs/<batch_id>/email.eml
# and a "would email" event is logged. See REPORT.md for the production-email roadmap.
EMAIL_ENABLED=false
EMAIL_FROM=noreply@jobpilot.local

# ---- Fit Intelligence cache ----
FIT_CACHE_DIR=.cache/fit
FIT_CACHE_REVIEWS_DAYS=30
FIT_CACHE_CAREERS_DAYS=7
